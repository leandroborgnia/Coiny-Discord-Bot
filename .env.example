# Copy to .env and fill in real values. .env is git-ignored — never commit secrets.

# --- Discord ---
# The bot registers /ping to every server it is in (and to new servers when it joins), so no
# server/guild id is needed.
DISCORD_TOKEN=your-bot-token-here

# --- Database (Postgres 17 in Docker) ---
# DB_PASSWORD is consumed by docker compose (Postgres) AND by the app.
DB_PASSWORD=change-me-locally
DB_URL=jdbc:postgresql://localhost:5432/coiny
DB_USERNAME=coiny

# --- Spring ---
SPRING_PROFILES_ACTIVE=dev
